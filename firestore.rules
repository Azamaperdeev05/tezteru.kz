rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidRacePlayer(player) {
      return player is map
        && player.keys().hasOnly(['displayName', 'progress', 'finished', 'wpm'])
        && player.displayName is string
        && player.progress is int
        && player.progress >= 0
        && player.progress <= 100
        && player.finished is bool
        && player.wpm is int
        && player.wpm >= 0;
    }

    function isValidRaceRoom(data) {
      return data.keys().hasOnly([
          'status',
          'targetText',
          'createdAt',
          'startedAt',
          'hostId',
          'playerCount',
          'finishedCount',
          'players'
        ])
        && (data.status == 'waiting' || data.status == 'playing' || data.status == 'finished')
        && data.targetText is string
        && data.createdAt is timestamp
        && (!data.keys().hasAny(['startedAt']) || data.startedAt is int)
        && data.hostId is string
        && data.playerCount is int
        && data.playerCount >= 1
        && data.finishedCount is int
        && data.finishedCount >= 0
        && data.finishedCount <= data.playerCount
        && data.players is map
        && data.players.keys().hasAll([data.hostId]);
    }

    function roomCoreIsUnchanged() {
      return request.resource.data.hostId == resource.data.hostId
        && request.resource.data.targetText == resource.data.targetText
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function roomPlayerCountIsUnchanged() {
      return request.resource.data.playerCount == resource.data.playerCount;
    }

    function roomStartedAtIsUnchanged() {
      return request.resource.data.startedAt == resource.data.startedAt;
    }

    function actorIsRoomPlayer() {
      return isSignedIn()
        && resource.data.players is map
        && resource.data.players.keys().hasAny([request.auth.uid])
        && request.resource.data.players.keys().hasAny([request.auth.uid]);
    }

    function actorOnlyUpdatesOwnPlayerEntry() {
      return request.resource.data.players.diff(resource.data.players).changedKeys().hasOnly([request.auth.uid])
        && request.resource.data.players.diff(resource.data.players).addedKeys().size() == 0
        && request.resource.data.players.diff(resource.data.players).removedKeys().size() == 0;
    }

    function actorKeepsIdentityFieldsStable() {
      return request.resource.data.players[request.auth.uid].displayName
          == resource.data.players[request.auth.uid].displayName;
    }

    function canCreateRoom() {
      return isSignedIn()
        && isValidRaceRoom(request.resource.data)
        && request.resource.data.status == 'waiting'
        && !request.resource.data.keys().hasAny(['startedAt'])
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.playerCount == 1
        && request.resource.data.finishedCount == 0
        && request.resource.data.players.keys().hasOnly([request.auth.uid])
        && isValidRacePlayer(request.resource.data.players[request.auth.uid])
        && request.resource.data.players[request.auth.uid].progress == 0
        && request.resource.data.players[request.auth.uid].finished == false
        && request.resource.data.players[request.auth.uid].wpm == 0;
    }

    function canJoinWaitingRoom() {
      return isSignedIn()
        && isValidRaceRoom(resource.data)
        && isValidRaceRoom(request.resource.data)
        && resource.data.status == 'waiting'
        && request.resource.data.status == 'waiting'
        && roomCoreIsUnchanged()
        && !request.resource.data.keys().hasAny(['startedAt'])
        && request.resource.data.finishedCount == resource.data.finishedCount
        && request.resource.data.playerCount == resource.data.playerCount + 1
        && !resource.data.players.keys().hasAny([request.auth.uid])
        && request.resource.data.players.diff(resource.data.players).addedKeys().hasOnly([request.auth.uid])
        && request.resource.data.players.diff(resource.data.players).changedKeys().hasOnly([request.auth.uid])
        && request.resource.data.players.diff(resource.data.players).removedKeys().size() == 0
        && isValidRacePlayer(request.resource.data.players[request.auth.uid])
        && request.resource.data.players[request.auth.uid].progress == 0
        && request.resource.data.players[request.auth.uid].finished == false
        && request.resource.data.players[request.auth.uid].wpm == 0;
    }

    function canStartRace() {
      return isSignedIn()
        && isValidRaceRoom(resource.data)
        && isValidRaceRoom(request.resource.data)
        && request.auth.uid == resource.data.hostId
        && resource.data.status == 'waiting'
        && request.resource.data.status == 'playing'
        && !resource.data.keys().hasAny(['startedAt'])
        && request.resource.data.startedAt is int
        && roomCoreIsUnchanged()
        && roomPlayerCountIsUnchanged()
        && request.resource.data.finishedCount == 0
        && request.resource.data.players == resource.data.players
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'startedAt', 'finishedCount']);
    }

    function canUpdateOwnProgress() {
      return actorIsRoomPlayer()
        && isValidRaceRoom(request.resource.data)
        && resource.data.status == 'playing'
        && request.resource.data.status == 'playing'
        && roomCoreIsUnchanged()
        && roomPlayerCountIsUnchanged()
        && roomStartedAtIsUnchanged()
        && request.resource.data.finishedCount == resource.data.finishedCount
        && actorOnlyUpdatesOwnPlayerEntry()
        && actorKeepsIdentityFieldsStable()
        && resource.data.players[request.auth.uid].finished == false
        && isValidRacePlayer(request.resource.data.players[request.auth.uid])
        && request.resource.data.players[request.auth.uid].finished == false
        && request.resource.data.players[request.auth.uid].progress < 100
        && request.resource.data.players[request.auth.uid].wpm == resource.data.players[request.auth.uid].wpm
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['players']);
    }

    function canFinishRace() {
      return actorIsRoomPlayer()
        && isValidRaceRoom(request.resource.data)
        && resource.data.status == 'playing'
        && roomCoreIsUnchanged()
        && roomPlayerCountIsUnchanged()
        && roomStartedAtIsUnchanged()
        && actorOnlyUpdatesOwnPlayerEntry()
        && actorKeepsIdentityFieldsStable()
        && isValidRacePlayer(request.resource.data.players[request.auth.uid])
        && request.resource.data.players[request.auth.uid].finished == true
        && request.resource.data.players[request.auth.uid].progress == 100
        && (!resource.data.players[request.auth.uid].finished
          || request.resource.data.players[request.auth.uid].wpm == resource.data.players[request.auth.uid].wpm)
        && request.resource.data.finishedCount
          == (resource.data.players[request.auth.uid].finished
            ? resource.data.finishedCount
            : resource.data.finishedCount + 1)
        && (
          (request.resource.data.status == 'playing'
            && request.resource.data.finishedCount < request.resource.data.playerCount)
          || (request.resource.data.status == 'finished'
            && request.resource.data.finishedCount == request.resource.data.playerCount)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['players', 'finishedCount', 'status']);
    }

    function canLeaveRoom() {
      return isSignedIn()
        && isValidRaceRoom(resource.data)
        && isValidRaceRoom(request.resource.data)
        && request.auth.uid != resource.data.hostId
        && resource.data.players.keys().hasAny([request.auth.uid])
        && !request.resource.data.players.keys().hasAny([request.auth.uid])
        && roomCoreIsUnchanged()
        && roomPlayerCountIsUnchanged() == false
        && roomStartedAtIsUnchanged()
        && request.resource.data.hostId == resource.data.hostId
        && request.resource.data.playerCount == resource.data.playerCount - 1
        && request.resource.data.finishedCount
          == (resource.data.players[request.auth.uid].finished
            ? resource.data.finishedCount - 1
            : resource.data.finishedCount)
        && request.resource.data.players.diff(resource.data.players).removedKeys().hasOnly([request.auth.uid])
        && request.resource.data.players.diff(resource.data.players).addedKeys().size() == 0
        && request.resource.data.players.diff(resource.data.players).changedKeys().size() == 0
        && (
          (resource.data.status == 'waiting' && request.resource.data.status == 'waiting')
          || (resource.data.status == 'finished' && request.resource.data.status == 'finished')
          || (resource.data.status == 'playing'
            && (
              (request.resource.data.finishedCount >= request.resource.data.playerCount
                && request.resource.data.status == 'finished')
              || (request.resource.data.finishedCount < request.resource.data.playerCount
                && request.resource.data.status == 'playing')
            ))
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['players', 'playerCount', 'finishedCount', 'status']);
    }

    function canDeleteRoom() {
      return isSignedIn()
        && isValidRaceRoom(resource.data)
        && resource.data.players.keys().hasAny([request.auth.uid])
        && (
          resource.data.hostId == request.auth.uid
          || resource.data.playerCount == 1
        );
    }

    // Жарыстар (Multiplayer Rooms)
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if canCreateRoom();
      allow update: if canJoinWaitingRoom()
        || canStartRace()
        || canUpdateOwnProgress()
        || canFinishRace()
        || canLeaveRoom();
      allow delete: if canDeleteRoom();
    }

    // Нәтижелер (Scores)
    match /scores/{scoreId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.uid
        && request.auth.uid == request.resource.data.uid;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }
    
    // Default deny for all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
